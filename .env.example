# Telegram Bot Token (from @BotFather)
TELEGRAM=

# PostgreSQL connection URLs
DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL_NN=postgresql://user:password@host:5432/dbname
DATABASE_URL_TEST=postgresql://user:password@host:5432/dbname_test

# Translation APIs
DEEPL=
OPENROUTER_API_KEY=

# Telegram channel / group IDs
CHANNEL_MEME=
CHANNEL_SOURCE=
CHANNEL_BACKUP=
CHANNEL_SUGGEST=
LOG_GROUP=

# JSON array of admin Telegram user IDs, e.g. [123456789, 987654321]
ADMINS=[]

# Runtime settings
PORT=8080
CONTAINER=false
RES_PATH=./res
TESTING=false

# Optional: override individual language channel IDs (defaults are in bot/data/languages.json)
# CHANNEL_ID_DE=
# CHANNEL_ID_EN=
# CHANNEL_ID_TR=
# CHANNEL_ID_FA=
# CHANNEL_ID_RU=
# CHANNEL_ID_PT=
# CHANNEL_ID_ES=
# CHANNEL_ID_FR=
# CHANNEL_ID_IT=
# CHANNEL_ID_AR=
# CHANNEL_ID_ID=

# Optional: override individual discussion group IDs
# CHAT_ID_DE=
# CHAT_ID_EN=
